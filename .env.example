DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Встановіть USE_SQLITE=True, щоб використовувати локальну базу SQLite замість PostgreSQL
USE_SQLITE=True

POSTGRES_DB=university_journal
POSTGRES_USER=journal_user
POSTGRES_PASSWORD=journal_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
